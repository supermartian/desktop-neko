[behavior]
initial_state = "idle"
tick_rate_ms = 100

[[states]]
name = "idle"
animation = "idle"
[[states.transitions]]
condition = { type = "falling" }
target = "fall"
priority = 90
[[states.transitions]]
condition = { type = "on_click", button = "left", count = 3 }
target = "annoyed"
priority = 10
[[states.transitions]]
condition = { type = "timer", min_seconds = 5.0, max_seconds = 10.0 }
targets = [
    { state = "trans_to_walk_right", weight = 0.5 },
    { state = "trans_to_walk_left", weight = 0.5 },
    { state = "trans_to_sleep", weight = 0.8 },
    { state = "happy", weight = 0.6 }
]


# --- TRANSITION STATES ---

[[states]]
name = "trans_to_pet"
animation = "trans1"
[[states.transitions]]
condition = { type = "animation_done" }
target = "walk_right"

[[states]]
name = "trans_to_walk_right"
animation = "alert"
[[states.transitions]]
condition = { type = "animation_done" }
target = "walk_right"

[[states]]
name = "trans_to_walk_left"
animation = "alert"
[[states.transitions]]
condition = { type = "animation_done" }
target = "walk_left"

[[states]]
name = "trans_to_sleep"
animation = "idle"
[[states.transitions]]
condition = { type = "animation_done" }
target = "sleep"

[[states]]
name = "trans_to_idle"
animation = "alert"
[[states.transitions]]
condition = { type = "animation_done" }
target = "idle"

# -------------------------


[[states]]
name = "walk_right"
animation = "walk_right"
movement = { direction = "right", speed_px_s = 30.0 }
[[states.transitions]]
condition = { type = "falling" }
target = "fall"
priority = 90
[[states.transitions]]
condition = { type = "on_click", button = "left", count = 3 }
target = "annoyed"
priority = 10
[[states.transitions]]
condition = { type = "at_edge", edge = "right" }
target = "trans_to_walk_left"
priority = 5
[[states.transitions]]
condition = { type = "timer", min_seconds = 3.0, max_seconds = 8.0 }
target = "trans_to_idle"

[[states]]
name = "walk_left"
animation = "walk_left"
movement = { direction = "left", speed_px_s = 60.0 }
[[states.transitions]]
condition = { type = "falling" }
target = "fall"
priority = 90
[[states.transitions]]
condition = { type = "on_click", button = "left", count = 3 }
target = "annoyed"
priority = 10
[[states.transitions]]
condition = { type = "at_edge", edge = "left" }
target = "trans_to_walk_right"
priority = 5
[[states.transitions]]
condition = { type = "timer", min_seconds = 3.0, max_seconds = 8.0 }
target = "trans_to_idle"

[[states]]
name = "sleep"
animation = "sleep"
[[states.transitions]]
condition = { type = "falling" }
target = "fall"
priority = 90
[[states.transitions]]
condition = { type = "on_click", button = "left", count = 3 }
target = "annoyed"
priority = 10
[[states.transitions]]
condition = { type = "timer", min_seconds = 10.0, max_seconds = 20.0 }
target = "trans_to_idle"

[[states]]
name = "happy"
animation = "happy"
[[states.transitions]]
condition = { type = "timer", min_seconds = 3.0, max_seconds = 5.0 }
target = "trans_to_idle"

[[states]]
name = "alert"
animation = "alert"
[[states.transitions]]
condition = { type = "timer", min_seconds = 5.0, max_seconds = 5.0 }
target = "trans_to_idle"

[[states]]
name = "annoyed"
animation = "alert"
[[states.transitions]]
condition = { type = "timer", min_seconds = 5.0, max_seconds = 5.0 }
targets = [
    { state = "trans_to_idle", weight = 1.0 },
    { state = "trans_to_walk_left", weight = 0.5 },
    { state = "trans_to_walk_right", weight = 0.5 }
]

[[states]]
name = "fall"
animation = "idle"
[[states.transitions]]
condition = { type = "falling" }
target = "fall"
priority = 10
[[states.transitions]]
condition = { type = "timer", min_seconds = 2.0, max_seconds = 4.0 }
target = "trans_to_idle"
